# Per-machine config — contains absolute paths. NEVER commit.
local_config.py

# OAuth tokens and runtime state — NEVER commit.
.ergodix_tokens.json
.ergodix_state.json
.ergodix.lock
ergodix.log

# Python virtual environment (regenerated by bootstrap.sh)
.venv/
__pycache__/
*.pyc
*.pyo

# Python packaging / test / lint caches
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Build artifacts (Pandoc output)
/build/

# Render artifacts — PDFs are reproducible from source via `ergodix render`.
*.pdf

# Creative source material — kept out of git by convention.
# Real creative files live in My Drive or the deployment directory,
# never in this source repo.
/creative/
/content/
*.gdoc
*.gsheet
*.gslides

# macOS
.DS_Store

# Editor / OS scratch
*.swp
.idea/
.vscode/

# Claude Code session logs (PreToolUse hook output — local backtrack only,
# never committed). See .claude/hooks/log-bash.sh.
ai.bashcommands.log
