{
  "permissions": {
    "allow": [
      "Bash(pytest *)",
      "Bash(ruff check *)",
      "Bash(ruff format --check *)",
      "Bash(mypy *)",
      "Bash(.venv/bin/pytest *)",
      "Bash(.venv/bin/ruff *)",
      "Bash(.venv/bin/mypy *)",
      "Bash(.venv/bin/python *)",
      "Bash(.venv/bin/pip *)",
      "Bash(.venv/bin/ergodix *)",
      "Bash(./bootstrap.sh)",
      "Bash(./bootstrap.sh *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git restore *)",
      "Bash(git rm *)",
      "Bash(git mv *)",
      "Bash(git stash *)",
      "Bash(git switch *)",
      "Bash(git tag *)",
      "Bash(git rebase --continue*)",
      "Bash(git rebase --abort*)",
      "Bash(git rebase --skip*)",
      "Bash(git cherry-pick *)",
      "Bash(git clone *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(rm *)",
      "Bash(chmod *)",
      "Bash(touch *)",
      "Bash(ln *)",
      "Bash(pip install *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D *)",
      "Bash(git branch -d *)",
      "Bash(git update-ref -d *)",
      "Bash(git filter-branch *)",
      "Bash(git filter-repo *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/*)",
      "Bash(rm -rf /Users)",
      "Bash(rm -rf /Users/*)",
      "Bash(rm -rf /System*)",
      "Bash(rm -rf /usr*)",
      "Bash(rm -rf /etc*)",
      "Bash(rm -rf /Library*)",
      "Bash(rm -rf /Applications*)",
      "Bash(brew install *)",
      "Bash(brew uninstall *)",
      "Bash(brew remove *)",
      "Bash(apt install *)",
      "Bash(apt-get install *)",
      "Bash(apt remove *)",
      "Bash(apt-get remove *)",
      "Bash(npm install -g *)",
      "Bash(yarn global *)",
      "Bash(pnpm install -g *)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(diskutil *)",
      "Bash(launchctl *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/log-bash.sh"
          }
        ]
      }
    ]
  }
}
